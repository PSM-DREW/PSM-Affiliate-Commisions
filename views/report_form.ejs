<%- include('layout', { body: `
<h1 style="font-size:22px; color:#7B4FFF; margin-bottom:16px;">${report ? 'Edit' : 'New'} Commission Report</h1>

<form method="POST" action="/report/save" id="reportForm">
  ${report ? '<input type="hidden" name="report_id" value="' + report.id + '">' : ''}
  <div class="grid-2">
    <div>
      <div class="card">
        <h2>Report Details</h2>
        <div class="form-group">
          <label>Affiliate *</label>
          <select name="affiliate_id" id="affiliateSelect" required ${report ? 'disabled' : 'onchange="loadAffiliate()"'}>
            <option value="">Select affiliate...</option>
            ${affiliates.map(a => '<option value="' + a.id + '" ' + ((report ? report.affiliate_id : selectedId) == a.id ? 'selected' : '') + '>' + a.username + '</option>').join('')}
          </select>
          ${report ? '<input type="hidden" name="affiliate_id" value="' + report.affiliate_id + '">' : ''}
        </div>
        <div class="grid-2">
          <div class="form-group">
            <label>Week Start (Monday) *</label>
            <input type="date" name="week_start" id="weekStart" required value="${report ? report.week_start : (preload ? preload.weekStart : '')}" onchange="recalc()">
          </div>
          <div class="form-group">
            <label>Week End (Sunday) *</label>
            <input type="date" name="week_end" id="weekEnd" required value="${report ? report.week_end : (preload ? preload.weekEnd : '')}">
          </div>
        </div>
        <div class="form-group">
          <label>Week Label</label>
          <input type="text" name="week_label" id="weekLabel" placeholder="e.g. Week 13" value="${report ? report.week_label : ''}">
        </div>
      </div>

      <div class="card">
        <h2>Performance Data</h2>
        <div class="grid-3">
          <div class="form-group">
            <label>Active Players *</label>
            <input type="number" name="active_players" id="activePlayers" min="0" value="${report ? report.active_players : 0}" required oninput="recalc()">
          </div>
          <div class="form-group">
            <label>Referred Players</label>
            <input type="number" name="referred_players" id="referredPlayers" min="0" value="${report ? (report.referred_players || 0) : 0}">
          </div>
          <div class="form-group">
            <label>NET SC *</label>
            <input type="number" name="net_sc" id="netSc" step="0.01" value="${report ? report.net_sc : 0}" required oninput="recalc()">
          </div>
        </div>
        <div class="grid-2">
          <div class="form-group">
            <label>Sold USD *</label>
            <input type="number" name="sold_usd" id="soldUsd" step="0.01" value="${report ? report.sold_usd : 0}" required oninput="recalc()">
          </div>
          <div class="form-group">
            <label>Bonuses</label>
            <input type="number" name="bonuses" id="bonuses" step="0.01" value="${report ? report.bonuses : 0}" oninput="recalc()">
          </div>
        </div>
      </div>

      <div class="card">
        <h2>Additional Expenses</h2>
        <div class="grid-2">
          <div class="form-group">
            <label>Adjustment</label>
            <input type="number" name="adjustment" id="adjustment" step="0.01" value="${report ? (report.adjustment || 0) : 0}" oninput="recalc()">
          </div>
          <div class="form-group">
            <label>Adjustment Note</label>
            <input type="text" name="adjustment_note" value="${report && report.adjustment_note ? report.adjustment_note : ''}" placeholder="e.g. 1.75% backtrack">
          </div>
        </div>
        <div id="extraExpenses">
          ${report && report.extraExpenses && report.extraExpenses.length > 0 ? report.extraExpenses.map(e => '<div class="grid-2 mb-2"><div class="form-group"><input type="text" name="extra_label" value="' + e.label + '" placeholder="Label"></div><div class="form-group" style="display:flex;gap:8px;"><input type="number" name="extra_amount" step="0.01" value="' + e.amount + '" placeholder="Amount" oninput="recalc()"><button type="button" class="btn btn-red btn-sm" onclick="this.parentElement.parentElement.remove();recalc()">x</button></div></div>').join('') : ''}
        </div>
        <button type="button" class="btn btn-outline btn-sm" onclick="addExtra()">+ Add Expense</button>
      </div>

      <div class="card">
        <h2>Rate Override (Optional)</h2>
        <div class="grid-2">
          <div class="form-group">
            <label>Override Rate (%)</label>
            <input type="number" name="rate_override" id="rateOverride" step="1" min="0" max="100" placeholder="Leave blank for auto" value="${report && report.rate_override_reason ? Math.round(report.commission_rate * 100) : ''}" oninput="recalc()">
          </div>
          <div class="form-group">
            <label>Reason</label>
            <input type="text" name="rate_override_reason" value="${report && report.rate_override_reason ? report.rate_override_reason : ''}" placeholder="Why override?">
          </div>
        </div>
      </div>
    </div>

    <div>
      <div class="card" id="calcPreview">
        <h2>Live Calculation</h2>
        <div id="calcResults" style="color:#888;">Select an affiliate and enter data to see calculations.</div>
      </div>

      <div class="card">
        <h2>Tier Qualification</h2>
        <table class="tier-table">
          <thead><tr><th>Rate</th><th>Players</th><th>Sold</th><th>Status</th></tr></thead>
          <tbody id="tierTable">
            ${[...tiers].reverse().map(t => '<tr data-rate="' + t.rate + '" data-players="' + t.players + '" data-sold="' + t.sold + '"><td>' + Math.round(t.rate * 100) + '%</td><td class="tier-players">' + t.players + '+</td><td class="tier-sold">$' + t.sold.toLocaleString() + '+</td><td class="tier-status">-</td></tr>').join('')}
          </tbody>
        </table>
        <div id="nextTierInfo" class="mt-4" style="font-size:12px; color:#7B4FFF;"></div>
      </div>

      <button type="submit" class="btn btn-gold" style="width:100%; padding:14px; font-size:15px;">
        ${report ? 'Update Report' : 'Save & Generate Report'}
      </button>
    </div>
  </div>
</form>

<script>
var editReportId = ${report ? report.id : 'null'};

function loadAffiliate() {
  var id = document.getElementById('affiliateSelect').value;
  if (id) window.location.href = '/report/new?affiliate_id=' + id;
}

function addExtra() {
  var html = '<div class="grid-2 mb-2"><div class="form-group"><input type="text" name="extra_label" placeholder="Label (e.g. Promo cost)"></div><div class="form-group" style="display:flex;gap:8px;"><input type="number" name="extra_amount" step="0.01" placeholder="Amount" oninput="recalc()"><button type="button" class="btn btn-red btn-sm" onclick="this.parentElement.parentElement.remove();recalc()">x</button></div></div>';
  document.getElementById('extraExpenses').insertAdjacentHTML('beforeend', html);
}

function getExtras() {
  var extras = [];
  var labels = document.querySelectorAll('input[name="extra_label"]');
  var amounts = document.querySelectorAll('input[name="extra_amount"]');
  for (var i = 0; i < labels.length; i++) {
    var l = (labels[i].value || '').trim();
    var a = parseFloat(amounts[i].value) || 0;
    if (l && a !== 0) extras.push({label: l, amount: a});
  }
  return extras;
}

var debounceTimer;
function recalc() {
  clearTimeout(debounceTimer);
  debounceTimer = setTimeout(doCalc, 200);
}

function fmt(n) {
  if (n == null) return '$0.00';
  var neg = n < 0, abs = Math.abs(n);
  var f = '$' + abs.toLocaleString('en-US', {minimumFractionDigits:2, maximumFractionDigits:2});
  return neg ? '-' + f : f;
}

function doCalc() {
  var affiliateId = document.getElementById('affiliateSelect').value;
  var weekStart = document.getElementById('weekStart').value;
  if (!affiliateId || !weekStart) return;

  var data = {
    affiliate_id: affiliateId,
    week_start: weekStart,
    active_players: document.getElementById('activePlayers').value || '0',
    net_sc: document.getElementById('netSc').value || '0',
    sold_usd: document.getElementById('soldUsd').value || '0',
    bonuses: document.getElementById('bonuses').value || '0',
    adjustment: document.getElementById('adjustment').value || '0',
    extra_expenses: JSON.stringify(getExtras()),
    rate_override: document.getElementById('rateOverride').value || '',
    exclude_report_id: editReportId || '',
  };

  fetch('/api/calculate', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify(data)
  })
  .then(function(r) { return r.json(); })
  .then(function(c) {
    var playerLines = c.playerHistory.map(function(h, i) { return 'Wk' + (i+1) + ': ' + h.count; }).join(' \\u00b7 ');
    var adj = parseFloat(data.adjustment) || 0;
    var extras = getExtras();
    var extrasHtml = '';
    extras.forEach(function(e) {
      extrasHtml += '<div class="calc-row"><span class="label">' + e.label + '</span><span class="value">' + fmt(e.amount) + '</span></div>';
    });

    document.getElementById('calcResults').innerHTML =
      '<div class="section-header">PLAYER AVERAGE</div>' +
      '<div class="calc-row"><span class="label">' + playerLines + '</span></div>' +
      '<div class="calc-row"><span class="label">4-week average</span><span class="value text-gold">' + c.playerAvg + ' players</span></div>' +
      '<div class="section-header">EXPENSES</div>' +
      '<div class="calc-row"><span class="label">Processing Fees (6.25%)</span><span class="value">' + fmt(c.processingFees) + '</span></div>' +
      '<div class="calc-row"><span class="label">Bonuses</span><span class="value">' + fmt(parseFloat(data.bonuses)) + '</span></div>' +
      (adj !== 0 ? '<div class="calc-row"><span class="label">Adjustment</span><span class="value">' + fmt(adj) + '</span></div>' : '') +
      extrasHtml +
      '<div class="calc-row"><span class="label">Total Expenses</span><span class="value text-gold">' + fmt(c.totalExpenses) + '</span></div>' +
      '<div class="section-header">NET CALCULATION</div>' +
      '<div class="calc-row"><span class="label">Net (NET SC - Expenses)</span><span class="value">' + fmt(c.net) + '</span></div>' +
      '<div class="calc-row"><span class="label">Carryover In</span><span class="value">' + (c.carryoverIn !== 0 ? fmt(c.carryoverIn) : 'None') + '</span></div>' +
      '<div class="calc-row"><span class="label">Payout Net</span><span class="value text-green">' + fmt(c.payoutNet) + '</span></div>' +
      '<div class="section-header">COMMISSION</div>' +
      '<div class="calc-row"><span class="label">Rate</span><span class="value">' + Math.round(c.commissionRate * 100) + '% (' + c.tierBasis + ')</span></div>' +
      '<div class="calc-row"><span class="label">Total Commission</span><span class="value text-gold" style="font-size:16px;">' + fmt(c.totalCommission) + '</span></div>' +
      (c.carryoverOut < 0 ? '<div class="calc-row"><span class="label text-red">Carryover Out</span><span class="value text-red">' + fmt(c.carryoverOut) + '</span></div>' : '');

    document.querySelectorAll('#tierTable tr').forEach(function(row) {
      var rate = parseFloat(row.dataset.rate);
      var reqPlayers = parseInt(row.dataset.players);
      var reqSold = parseInt(row.dataset.sold);
      var meetsPlayers = c.playerAvg >= reqPlayers;
      var meetsSold = parseFloat(data.sold_usd) >= reqSold;
      var meetsBoth = meetsPlayers && meetsSold;
      row.className = (c.commissionRate === rate) ? 'tier-active' : '';
      row.querySelector('.tier-players').className = 'tier-players ' + (meetsPlayers ? 'tier-check' : 'tier-miss');
      row.querySelector('.tier-sold').className = 'tier-sold ' + (meetsSold ? 'tier-check' : 'tier-miss');
      row.querySelector('.tier-status').innerHTML = meetsBoth ? '<span class="tier-check">\\u2713</span>' : '<span class="tier-miss">\\u2717</span>';
    });

    if (c.nextTier) {
      var parts = [];
      if (c.nextTier.playersNeeded > 0) parts.push(Math.ceil(c.nextTier.playersNeeded) + ' more avg players');
      if (c.nextTier.soldNeeded > 0) parts.push(fmt(c.nextTier.soldNeeded) + ' more sold');
      document.getElementById('nextTierInfo').textContent = 'Next tier (' + Math.round(c.nextTier.tier.rate*100) + '%): ' + parts.join(' & ');
    } else {
      document.getElementById('nextTierInfo').textContent = 'At maximum tier!';
    }
  });
}

if (document.getElementById('affiliateSelect').value) recalc();
</script>
` }) %>
